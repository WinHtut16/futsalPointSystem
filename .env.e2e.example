# ──────────────────────────────────────────────────────────────
# E2E test environment — copy to .env.e2e and fill in the blanks
# NEVER commit .env.e2e (it contains real credentials)
# ──────────────────────────────────────────────────────────────

# Base URL of the running Next.js app
E2E_BASE_URL=http://localhost:3000

# Supabase project — needed by global-setup/teardown to manage test data
# (same values as in your .env.local)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Superadmin ───────────────────────────────────────────────
# The superadmin account seeded by setup-admin.mjs.
# Used for both Journey 2 (admin adds points) and Journey 3.
E2E_SUPERADMIN_EMAIL=your-superadmin@email.com
E2E_SUPERADMIN_PASSWORD=your-superadmin-password

# ── Pre-seeded test customer (Journey 1 & 2) ─────────────────
# global-setup creates/updates this account and seeds E2E_CUSTOMER_POINTS.
# Phone must match the Myanmar format: 09XXXXXXX (7-9 digits after 09).
E2E_CUSTOMER_PHONE=09111000001
E2E_CUSTOMER_PASSWORD=TestCust123!
E2E_CUSTOMER_USERNAME=E2ECustomer
E2E_CUSTOMER_POINTS=500

# ── Ephemeral registration customer (Journey 1 only) ─────────
# global-setup deletes any leftover from previous run.
# global-teardown deletes it after the suite finishes.
E2E_NEW_CUSTOMER_PHONE=09111000002
E2E_NEW_CUSTOMER_PASSWORD=TestNew456!

# ── Test reward for customer redemption (Journey 1) ──────────
# global-setup creates this reward if it doesn't exist.
# global-teardown deletes it. Points must be <= E2E_CUSTOMER_POINTS.
E2E_REWARD_NAME=E2E Test Reward
E2E_REWARD_POINTS=100

# ── Journey 3 test data ───────────────────────────────────────
# Created and deleted within the Journey 3 tests themselves.
# global-setup cleans up any leftovers from a previous failed run.
E2E_STAFF_USERNAME=e2eteststaff
E2E_STAFF_PASSWORD=TestStaff123
E2E_J3_REWARD_NAME=E2E Journey3 Reward
E2E_J3_REWARD_POINTS=50
